{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apix",
  "version": "0.1.0",
  "identifier": "dev.apix.desktop",
  "build": {
    "beforeBuildCommand": "pnpm --dir .. build:sidecar && pnpm --dir ../apps/desktop build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../apps/desktop/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Apix",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/apix-runtime"],
    "icon": []
  }
}
